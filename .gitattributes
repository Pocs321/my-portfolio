# Auto detect text files and perform LF normalization
* text=auto

# Terraform files must always use LF line endings (for terraform fmt)
*.tf text eol=lf
*.tfvars text eol=lf
*.hcl text eol=lf

# Shell scripts must use LF
*.sh text eol=lf

# Batch files use CRLF
*.bat text eol=crlf

# GitHub Actions workflows
*.yml text eol=lf
*.yaml text eol=lf
